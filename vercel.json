{
  "buildCommand": "cd ai-cricket-predictor && npm install && npm run build",
  "outputDirectory": "ai-cricket-predictor/dist",
  "framework": null,
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/predict", "destination": "/api/index.py" },
    { "source": "/api/history", "destination": "/api/index.py" },
    { "source": "/api/match_details/:path*", "destination": "/api/index.py" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
